rules_version = '2';

// ============================================================================
// SECURITY RULES — POS MONIKA MULYA (VERSI SAAS MULTI-TENANT)
// Tempel isi file ini di: Firebase Console → Firestore Database → Rules → Publish
// ============================================================================

service cloud.firestore {
  match /databases/{database}/documents {

    function signedIn() {
      return request.auth != null;
    }

    // 1. DATA GLOBAL (Akses Root)
    // Profil user global yang mengikat login ke sistem SaaS.
    match /global_users/{uid} {
      allow read: if true; 
      allow write: if signedIn(); 
    }

    // 2. DATA KAMAR TENANT (Arsitektur SaaS)
    // Semua aktivitas operasional (kasir, barang, transaksi) dikerjakan di dalam sini.
    match /tenants/{tenantId} {
      allow read, write: if signedIn();
    }
    
    match /tenants/{tenantId}/{document=**} {
      allow read, write: if signedIn(); // Operasional POS SaaS berlangsung di sini
    }

    // 3. PROTEKSI DATA LAMA (hxpos2)
    // Ini mengunci seluruh koleksi root lama (Sistem Single Tenant sebelumnya).
    // DIJAMIN 100% AMAN! Data lama hanya diizinkan untuk DIBACA (Read-Only) saat proses 
    // migrasi nanti, dan DITOLAK KERAS jika ada yang mencoba mengubah/menghapus!
    match /{legacyCollection}/{docId} {
      allow read: if signedIn() && legacyCollection in [
        'users', 'products', 'sales', 'purchases', 'customers', 'suppliers',
        'accounting', 'financialAccounts', 'shiftHistory', 'settings', 'activityLogs'
      ];
      allow write: if false; // PENGUNCIAN MUTLAK! Data HXPOS2 tidak bisa diubah!
    }

  }
}
